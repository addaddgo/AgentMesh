{
  "name": "@agentmesh/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--conditions=development' tsx watch src/index.ts",
    "build": "pnpm --filter @agentmesh/shared build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @agentmesh/shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run src/integration-smoke.test.ts",
    "test:smoke:codex": "AGENTMESH_REAL_CODEX_SMOKE=1 vitest run src/integration-smoke.test.ts -t \"real local codex\"",
    "test:smoke:ssh": "AGENTMESH_SSH_SMOKE=1 vitest run src/integration-smoke.test.ts -t \"remote codex\""
  },
  "dependencies": {
    "@agentmesh/shared": "workspace:*",
    "@fastify/multipart": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.19.4",
    "vitest": "^3.1.3"
  }
}
