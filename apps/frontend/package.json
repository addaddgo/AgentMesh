{
  "name": "@agentmesh/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "pnpm --filter @agentmesh/shared build && vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @agentmesh/shared build && vue-tsc -b --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agentmesh/shared": "workspace:*",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "codemirror": "^6.0.2",
    "element-plus": "^2.14.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vite": "^6.3.5",
    "vue": "^3.5.14",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "vitest": "^3.1.3",
    "vue-tsc": "^2.2.10"
  }
}
